{
  "$schema": "http://json.schemastore.org/template",
  "author": "adofaiex",
  "classifications": ["ADOFAI", "Mod", "Game", "Multi-Loader"],
  "identity": "AdofaiMod.MultiLoader",
  "name": "ADOFAI Multi-Loader Mod Template",
  "shortName": "adofaiml",
  "tags": {
    "language": "C#",
    "type": "project"
  },
  "sourceName": "AdofaiMod.MultiLoader",
  "preferNameDirectory": true,
  "symbols": {
    "ModDescription": {
      "type": "parameter",
      "datatype": "text",
      "replaces": "ADOFAI Multi-Loader Mod Template",
      "defaultValue": "My ADOFAI Mod",
      "description": "Mod description"
    },
    "Author": {
      "type": "parameter",
      "datatype": "text",
      "replaces": "Your Name",
      "defaultValue": "Anonymous",
      "description": "Author name"
    },
    "Version": {
      "type": "parameter",
      "datatype": "text",
      "replaces": "1.0.0",
      "defaultValue": "1.0.0",
      "description": "Initial version"
    },
    "GameExePath": {
      "type": "parameter",
      "datatype": "text",
      "replaces": "GAME_EXE_PATH_PLACEHOLDER",
      "defaultValue": "",
      "description": "Game executable path (for assembly references and auto-deploy)"
    },
    "UmmLoader": {
      "type": "parameter",
      "datatype": "bool",
      "defaultValue": "true",
      "description": "Include Unity Mod Manager loader"
    },
    "MelonLoader": {
      "type": "parameter",
      "datatype": "bool",
      "defaultValue": "true",
      "description": "Include MelonLoader loader"
    },
    "BepInExLoader": {
      "type": "parameter",
      "datatype": "bool",
      "defaultValue": "true",
      "description": "Include BepInEx loader"
    },
    "DoorstopLoader": {
      "type": "parameter",
      "datatype": "bool",
      "defaultValue": "true",
      "description": "Include Doorstop standalone loader"
    }
  },
  "sources": [
    {
      "modifiers": [
        {
          "condition": "!(UmmLoader)",
          "exclude": ["loaders/umm/**", "Info.json"]
        },
        {
          "condition": "!(MelonLoader)",
          "exclude": ["loaders/melon/**"]
        },
        {
          "condition": "!(BepInExLoader)",
          "exclude": ["loaders/bepinex/**"]
        },
        {
          "condition": "!(DoorstopLoader)",
          "exclude": ["loaders/doorstop/**"]
        }
      ]
    }
  ]
}
